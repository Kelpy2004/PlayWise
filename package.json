{
  "name": "playwise-frontend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "React frontend for the PlayWise gaming decision platform.",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite",
